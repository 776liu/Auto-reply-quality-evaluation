# ==========================================
# 硅基流动 API + 模型配置（示例文件）
# 复制为 model.yaml 并填入你的真实 API Key
# ==========================================

api:
  base_url: "https://api.siliconflow.cn/v1"
  key: "your-api-key-here"

model:
  name: "deepseek-ai/DeepSeek-V3"
  temperature: 0.1
  max_tokens: 1024
  top_p: 0.9

retry:
  max_attempts: 3
  backoff_timeout: [1, 2, 4]        # 超时重试间隔（秒）
  backoff_server_error: [5, 10]     # 429/502/503 重试间隔（秒）
